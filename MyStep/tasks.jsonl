    },
    {
      "criterion": "Defines at least two methods with parameters and return types (e.g., ComputeSubtotal(...), ComputeDiscount(...), ComputeFee(...)) and the public calculation method calls them to produce the final result.",
      "related_learning_objective": 10
    },
    {
      "criterion": "Defines and throws a custom exception type when any line item has quantity <= 0 or unit price < 0, and normal calculation does not proceed in those cases.",
      "related_learning_objective": 14
    },
    {
      "criterion": "When promo code is provided, promo discount is applied only when the promo code matches an allowed value AND the subtotal meets a minimum threshold; otherwise promo discount is 0.",
      "related_learning_objective": 0
    },
    {
      "criterion": "Final total equals subtotal minus total discount plus payment fee, and the returned summary exposes all four computed values (subtotal, discount, fee, total).",
      "related_learning_objective": 0
    }
  ],
  "hints": [
