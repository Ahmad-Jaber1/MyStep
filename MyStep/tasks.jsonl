    },
    {
      "skill_name": "ASP.NET Core Logic",
      "used_learning_goal": 13,
      "justification": "Reading inputs from HttpContext.Request.Headers is required to obtain destination zone, weight, and expedited values."
    },
    {
      "skill_name": "ASP.NET Core Logic",
