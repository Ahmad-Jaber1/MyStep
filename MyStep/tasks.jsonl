    },
    {
      "skill_name": "C# Basics",
      "used_learning_goal": 14,
      "justification": "Unsupported regions must be signaled as a custom exception type so automated evaluation can verify the failure mode deterministically."
    },
    {
      "skill_name": "LINQ & Advanced C# Concepts",
