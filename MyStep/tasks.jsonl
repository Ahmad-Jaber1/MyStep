  "scenario": {
    "story": "A company sends notifications when a support ticket changes status. Depending on user preference, the system should send the message via Email, SMS, or a Chat channel. Some channels have restrictions (e.g., SMS message length), and if the preferred channel fails validation, the system should fall back to Email and record a reason for the fallback.",
    "requirement": "Implement a single feature that builds and sends a ticket-update notification using a simple Factory pattern to select the appropriate sender. The feature must validate inputs (recipient, message, and channel), apply conditional rules, and throw a custom exception for invalid notification requests. The public API should return a result indicating which channel was used and whether fallback occurred."
  },
  "targeted_objectives": [5, 7, 10, 14],
  "additional_skills_required": [
    {
      "skill_name": "OOP (Object-Oriented Programming)",
      "used_learning_goal": 7,
