}

{
  "task_name": "Idempotent Task Completion Audit with Singleton Clock and Repository Storage",
  "skill_category": "Design Patterns & SOLID",
  "scenario": {
    "story": "A compliance-focused team uses a task app where completing a task must create an audit record (who completed it and when). Support discovered duplicate audit records when users double-click the complete button or clients retry requests. The business rule is: the first transition from not-done to done creates exactly one audit entry; subsequent attempts to complete an already-done task must not create additional audit records.",
    "requirement": "Implement a feature that records a completion audit entry exactly once when a task is completed for the first time. The service must retrieve and persist data via repository abstractions. Time must come from a singleton clock abstraction to keep timestamps consistent and testable. The service must depend on abstractions, and the clock must guarantee a single thread-safe instance."
  },
  "targeted_objectives": [1, 5, 6, 7],
  "additional_skills_required": [
    {
      "skill_name": "LINQ & Advanced C# Concepts",
      "used_learning_goal": 2,
      "justification": "Required to query existing audit entries (e.g., Any/Where) in the repository implementation to enforce idempotency in a concise, verifiable way."
    }
  ],
  "instructions": [
    "Create minimal models representing a task (id, done flag) and a completion audit record (task id, completed by user id, completed at timestamp). Keep them small and focused on this feature only.",
    "Define repository abstractions: one for reading/updating tasks and one for adding/querying completion audit records. Provide in-memory implementations suitable for automated tests.",
    "Design a clock abstraction that returns the current UTC time. Implement a singleton clock that ensures only one instance exists and is safe under concurrent access.",
    "Implement a task completion service with a single responsibility: mark a task as done (if not already), and create exactly one audit record on the first transition to done.",
    "The completion service must use the clock abstraction to obtain the completion timestamp and must never call DateTime.UtcNow directly.",
    "Enforce idempotency: if the task is already done, do not create a new audit record and do not modify existing audit data.",
    "Make sure all dependencies are injected via abstractions (repositories + clock), so the service is easy to unit test with fakes/in-memory implementations."
  ],
  "validation_criteria": [
    {
      "criterion": "The completion service contains only orchestration logic for completing a task and creating an audit record; it does not contain persistence storage structures or direct data storage logic.",
      "related_learning_objective": 1
    },
    {
      "criterion": "The completion service depends only on abstractions (task repository interface, audit repository interface, and clock interface) and not on concrete implementations.",
      "related_learning_objective": 5
    },
    {
      "criterion": "A repository pattern is used for both tasks and audit records (interfaces + implementations), and the completion service uses these interfaces to read/write data.",
      "related_learning_objective": 6
    },
    {
      "criterion": "A singleton clock implementation exists and guarantees a single instance accessible in a thread-safe way (e.g., via Lazy<T> or equivalent).",
      "related_learning_objective": 7
    },
    {
      "criterion": "When completing a task that is initially not done, exactly one audit record is created with matching task id and completed-by user id.",
      "related_learning_objective": 0
    },
    {
      "criterion": "When completing the same task again after it is already done, no additional audit records are created (audit record count remains unchanged).",
      "related_learning_objective": 0
    },
    {
      "criterion": "The completion timestamp used in the audit record comes from the clock abstraction (no direct DateTime.UtcNow usage in the service).",
      "related_learning_objective": 0
    }
  ],
  "hints": [
    "Model idempotency as: “detect first transition to done” rather than “always write audit”.",
    "Keep repositories small: one focused on tasks, one focused on audit records.",
    "Introduce an IClock interface so your service can be tested without relying on real time.",
    "Use a thread-safe singleton pattern for the clock (Lazy initialization is a common approach).",
    "To prevent duplicate audits, check task state and/or existing audit entries before adding a new record.",
    "Write a test scenario in your head: call CompleteTask twice and ensure only one audit entry exists."
  ]
}

