      "related_learning_objective": 7
    },
    {
      "criterion": "Defines at least two methods with parameters and return types (for parsing/validation and for fee calculation) and the middleware Invoke/InvokeAsync method calls them.",
      "related_learning_objective": 10
    },
    {
      "criterion": "Implements a custom ASP.NET Core middleware class that reads inputs from HttpContext.Request.Headers and executes in the pipeline.",
      "related_learning_objective": 0
    },
    {
      "criterion": "When the request is valid, the middleware adds a response header named \"X-Shipping-Fee\" containing the computed fee as a string.",
      "related_learning_objective": 0
    },
    {
      "criterion": "When the request is invalid, the middleware sets HttpContext.Response.StatusCode to 400 and does not call the next middleware delegate.",
      "related_learning_objective": 0
    },
